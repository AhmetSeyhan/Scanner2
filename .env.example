# Scanner Environment Configuration
# Copy this file to .env and update with production values
#
# IMPORTANT: Never commit .env to version control

# =====================================================================
# REQUIRED - Authentication & Security
# =====================================================================

# JWT signing secret (generate with: openssl rand -hex 32)
SCANNER_SECRET_KEY=change-this-to-a-secure-random-string

# API key for service-to-service authentication (generate with: openssl rand -hex 24)
SCANNER_API_KEY=scanner-dev-key-2026

# =====================================================================
# OPTIONAL - Redis (required for rate limiting)
# =====================================================================

REDIS_URL=redis://localhost:6379/0

# =====================================================================
# OPTIONAL - S3/MinIO Storage
# =====================================================================

S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=scanner
AWS_SECRET_ACCESS_KEY=scanner2026
S3_BUCKET_NAME=scanner-analyses

# MinIO Console Credentials (Docker deployment only)
MINIO_ROOT_USER=scanner
MINIO_ROOT_PASSWORD=scanner2026

# =====================================================================
# OPTIONAL - Application Settings
# =====================================================================

# Rate limit (requests per minute per IP)
RATE_LIMIT=10

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Max upload size in bytes (500 MB)
MAX_UPLOAD_SIZE=524288000

# Webhook URL for scan notifications (leave empty to disable)
WEBHOOK_URL=

# =====================================================================
# OPTIONAL - Model Configuration
# =====================================================================

# Path to model weights (default: ./weights/)
WEIGHTS_DIR=./weights

# Device for inference (cpu, cuda, cuda:0)
DEVICE=cpu
